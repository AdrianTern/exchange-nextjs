## 📐 TypeScript Types ([types/exchange.ts](file:///c:/Users/yoeth/Documents/exchange/exchange/frontend/exchange-frontend/src/types/exchange.ts))

```typescript
export type CurrencyMap = Record<string, string>;

export type TrendDirection = 'UP' | 'DOWN' | 'STABLE';

export interface RateConversion {
  from: string;
  to: string;
  amount: number;
  rate: number;
  convertedAmount: number;
  date: string;
}

export interface RateComparison {
  from: string;
  to: string;
  currentRate: number;
  previousRate: number;
  absoluteChange: number;
  percentageChange: number;
  trend: TrendDirection;
  date: string;
}

export interface ApiError {
  message: string;
  status: number;
  timestamp: string;
  path: string;
}
```

